# Copy to .env and fill in. Generate hex secrets with: openssl rand -hex 32 (or -hex 16)

CLICKHOUSE_PASSWORD=changeme

LANGFUSE_SALT=<openssl rand -hex 16>
LANGFUSE_ENCRYPTION_KEY=<openssl rand -hex 32>
LANGFUSE_NEXTAUTH_SECRET=<openssl rand -hex 32>
LANGFUSE_PUBLIC_KEY=pk-lf-anything
LANGFUSE_SECRET_KEY=sk-lf-anything
LANGFUSE_ADMIN_EMAIL=you@example.com
LANGFUSE_ADMIN_PASSWORD=changeme
REDIS_AUTH=changeme
MINIO_ROOT_PASSWORD=changeme

LITELLM_MASTER_KEY=sk-<openssl rand -hex 16>

OPENAI_API_KEY=sk-...
